SMALL: 'SMALL';
PERCENTILE: 'PERCENTILE'|'PERCENTILE.INC';
PERCENTRANK: 'PERCENTRANK'|'PERCENTRANK.INC';
AVERAGE: 'AVERAGE';
AVERAGEIF: 'AVERAGEIF';
