GAMMAINV: 'GAMMAINV'|'GAMMA.INV';
GAMMALN: 'GAMMALN'|'GAMMALN.PRECISE';
HYPGEOMDIST: 'HYPGEOMDIST'|'HYPGEOM.DIST';
LOGINV: 'LOGINV'|'LOGNORM.INV';
LOGNORMDIST: 'LOGNORMDIST'|'LOGNORM.DIST';
