BETAINV: 'BETAINV'|'BETA.INV';
BINOMDIST: 'BINOMDIST'|'BINOM.DIST';
EXPONDIST: 'EXPONDIST'|'EXPON.DIST';
FDIST: 'FDIST'|'F.DIST';
FINV: 'FINV'|'F.INV';
